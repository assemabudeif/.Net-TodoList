{
  "info": {
    "name": "TodoList API",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Postman collection for the TodoList ASP.NET Core API. Includes JWT auth with auto-token saving and full CRUD for tasks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5050",
      "type": "string",
      "description": "Base URL of the running API. Change to your deployed URL if needed."
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT access token. Populated automatically after Login or Register."
    },
    {
      "key": "taskId",
      "value": "1",
      "type": "string",
      "description": "Task ID used in single-task requests."
    },
    {
      "key": "userId",
      "value": "1",
      "type": "string",
      "description": "User ID used in get-tasks-by-user request."
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.accessToken);",
                  "    pm.collectionVariables.set('userId', String(json.userId));",
                  "    console.log('Token saved:', json.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user. On success the JWT access token is automatically saved to the `token` collection variable."
          },
          "response": [
            {
              "name": "200 OK - Registered",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"userId\": 1,\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"dateCreated\": \"2026-04-27T10:00:00Z\",\n  \"dateModified\": null\n}"
            },
            {
              "name": "400 Bad Request - Registration Failed",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"Registration failed\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.accessToken);",
                  "    pm.collectionVariables.set('userId', String(json.userId));",
                  "    console.log('Token saved:', json.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login with existing credentials. On success the JWT access token is automatically saved to the `token` collection variable."
          },
          "response": [
            {
              "name": "200 OK - Logged In",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"userId\": 1,\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"dateCreated\": \"2026-04-27T10:00:00Z\",\n  \"dateModified\": null\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [],
              "body": ""
            }
          ]
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get All Tasks",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/task",
              "host": ["{{baseUrl}}"],
              "path": ["api", "task"]
            },
            "description": "Returns all tasks. Requires JWT."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 1,\n    \"name\": \"Buy groceries\",\n    \"description\": \"Milk, eggs, bread, and butter\",\n    \"isDone\": false,\n    \"userId\": 1,\n    \"dateCreated\": \"2026-04-27T10:05:00Z\",\n    \"dateModified\": \"0001-01-01T00:00:00Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Get Task By ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/task/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "task", "{{taskId}}"]
            },
            "description": "Returns a single task by its ID."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"name\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread, and butter\",\n  \"isDone\": false,\n  \"userId\": 1,\n  \"dateCreated\": \"2026-04-27T10:05:00Z\",\n  \"dateModified\": \"0001-01-01T00:00:00Z\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Get Tasks By User ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/task/user/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "task", "user", "{{userId}}"]
            },
            "description": "Returns all tasks belonging to a specific user."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 1,\n    \"name\": \"Buy groceries\",\n    \"description\": \"Milk, eggs, bread, and butter\",\n    \"isDone\": false,\n    \"userId\": 1,\n    \"dateCreated\": \"2026-04-27T10:05:00Z\",\n    \"dateModified\": \"0001-01-01T00:00:00Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('taskId', String(json.id));",
                  "    console.log('Task ID saved:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread, and butter\",\n  \"isDone\": false,\n  \"userId\": {{userId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/task",
              "host": ["{{baseUrl}}"],
              "path": ["api", "task"]
            },
            "description": "Creates a new task. On success the new task ID is saved to `taskId` collection variable."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"name\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread, and butter\",\n  \"isDone\": false,\n  \"userId\": 1,\n  \"dateCreated\": \"2026-04-27T10:05:00Z\",\n  \"dateModified\": \"0001-01-01T00:00:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Update Task",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Buy groceries updated\",\n  \"description\": \"Milk, eggs, bread, butter, and coffee\",\n  \"isDone\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/task/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "task", "{{taskId}}"]
            },
            "description": "Fully updates a task by ID."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"name\": \"Buy groceries updated\",\n  \"description\": \"Milk, eggs, bread, butter, and coffee\",\n  \"isDone\": false,\n  \"userId\": 1,\n  \"dateCreated\": \"2026-04-27T10:05:00Z\",\n  \"dateModified\": \"2026-04-27T11:00:00Z\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Toggle Task Completion",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/task/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "task", "{{taskId}}"]
            },
            "description": "Toggles the `isDone` field of a task. No request body needed."
          },
          "response": [
            {
              "name": "200 OK - Toggled",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"name\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread, and butter\",\n  \"isDone\": true,\n  \"userId\": 1,\n  \"dateCreated\": \"2026-04-27T10:05:00Z\",\n  \"dateModified\": \"2026-04-27T11:00:00Z\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Delete Task",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/task/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "task", "{{taskId}}"]
            },
            "description": "Deletes a task by ID."
          },
          "response": [
            {
              "name": "200 OK - Deleted",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Deleted successfully\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": ""
            }
          ]
        }
      ]
    }
  ]
}

